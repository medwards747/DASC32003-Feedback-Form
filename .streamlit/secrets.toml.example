# .streamlit/secrets.toml.example
# ─────────────────────────────────────────────────────────────────────────────
# Copy to .streamlit/secrets.toml and fill in your values.
# NEVER commit secrets.toml — it is in .gitignore.
#
# KEY GUIDE
# ─────────────────────────────────────────────────────────────────────────────
# SUPABASE_URL         Project URL from Supabase → Settings → API
#
# SUPABASE_ANON_KEY    "anon / public" key from the same page.
#                      Used by the Streamlit app (tabs 1 & 2 — students).
#                      RLS limits it to: SELECT on teams/students,
#                      INSERT-only on submissions/peer_reviews.
#                      Safe to add to Streamlit Community Cloud secrets.
#
# SUPABASE_SERVICE_KEY "service_role / secret" key from the same page.
#                      Used ONLY by tab 3 (Download Results) and
#                      generate_report.py on the professor's machine.
#                      Bypasses RLS — full read access to all data.
#                      DO NOT add to Streamlit Community Cloud.
#
# PROFESSOR_ID         A long random number you choose (e.g. 9 digits).
#                      Entered in the Download Results tab to authenticate.
#                      Store only here — never in the database.
# ─────────────────────────────────────────────────────────────────────────────

SUPABASE_URL         = "https://your-project-id.supabase.co"
SUPABASE_ANON_KEY    = "your-anon-key-here"
SUPABASE_SERVICE_KEY = "your-service-role-key-here"
PROFESSOR_ID         = "your-chosen-professor-id-here"
